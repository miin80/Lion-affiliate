PORT=3001
# CORS origin của frontend (Vite dev = http://localhost:5173).
# Production: đặt URL Vercel của bạn.
CORS_ORIGIN=http://localhost:5173

# Tắt Puppeteer (chỉ dùng axios + cheerio + Open Graph).
# Nhanh hơn nhưng sẽ FAIL với Shopee/TikTok/Lazada do chặn bot/SPA.
USE_PUPPETEER=true

# Đường dẫn Chrome (tuỳ chọn). Để trống thì Puppeteer dùng Chromium đi kèm.
# Windows ví dụ: C:\Program Files\Google\Chrome\Application\chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# ============ AUTH ============
# Đăng nhập /admin. ĐỪNG commit file .env thật lên GitHub.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeMe-StrongPassword123!
# JWT secret — chuỗi random càng dài càng tốt (min 32 ký tự).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-long-random-string-min-32-chars
