<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap tĩnh cho Lion Affiliate.
  Liệt kê các route public chính. Sản phẩm/blog động sẽ được crawl theo
  internal link từ Home → category → product detail (rel canonical đã có
  trong từng trang qua react-helmet-async).
  Đổi domain ở các <loc> bên dưới khi deploy production domain riêng.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://lion-affiliate.vercel.app/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://lion-affiliate.vercel.app/products</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://lion-affiliate.vercel.app/videos</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://lion-affiliate.vercel.app/blog</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://lion-affiliate.vercel.app/collections</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
</urlset>
