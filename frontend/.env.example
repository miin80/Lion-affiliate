# URL backend scraping. Khi deploy Vercel: trỏ tới backend production (vd: Render, Fly, Railway).
# Trống = dùng same-origin /api (cần Vercel rewrite hoặc proxy).
VITE_API_URL=http://localhost:3001

# Bật/tắt demo data trên website public.
# - true  = hiện 12 sản phẩm mẫu, 6 video, 5 collection... khi backend trống (dùng cho dev/test UI)
# - false = không hiện demo. Section trống = empty state hoặc ẩn (production)
VITE_SHOW_DEMO_DATA=false
